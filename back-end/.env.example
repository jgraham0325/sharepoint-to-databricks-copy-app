# Microsoft Entra ID (Azure AD) app registration
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret
MS_TENANT_ID=your-tenant-id

# Databricks (for local development only; auto-injected in Databricks Apps)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-personal-access-token
# Optional: model for the chat agent (Foundation Model API). Default: databricks-meta-llama-3-3-70b-instruct
# DATABRICKS_CHAT_MODEL=databricks-meta-llama-3-3-70b-instruct

# App URL (used to build the MS OAuth redirect URI)
APP_URL=http://localhost:8000

# Large file handling: files at or above this size (bytes) are transferred by a Databricks job instead of the app server. Default: 104857600 (100 MiB). Lower this (e.g. 52428800 for 50 MiB) to send more files to the job and keep the app server responsive when transferring many large files.
# LARGE_FILE_THRESHOLD_BYTES=104857600
# Optional: job ID of the sharepoint-transfer job (from bundle). If unset, the app looks up the job by name "sharepoint-transfer".
# SHAREPOINT_TRANSFER_JOB_ID=12345
